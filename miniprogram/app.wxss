page,
.dark-theme {
  --bg-primary: #1E1E1E;
  --bg-secondary: #2C2C2C;
  --bg-tertiary: #3A3A3A;
  --bg-sidebar: #1A1A1A;
  --text-primary: #F5F5F5;
  --text-secondary: rgba(235, 235, 245, 0.6);
  --text-tertiary: rgba(235, 235, 245, 0.3);
  --text-on-accent: #FFFFFF;
  --separator: rgba(255, 255, 255, 0.1);
  --accent: #FF9F0A;
  --accent-pressed: #D98300;
  --accent-soft: rgba(255, 159, 10, 0.16);
  --danger: #D85A5A;
  --danger-soft: rgba(216, 90, 90, 0.14);
  --info: #64A8E8;
  --success: #55B982;
  --macro-carbs: #4FAE78;
  --macro-protein: #548FCB;
  --macro-fat: #C98A36;
  --overlay: rgba(0, 0, 0, 0.72);
  --shadow: rgba(0, 0, 0, 0.22);
}

.light-theme {
  --bg-primary: #F2F2F7;
  --bg-secondary: #FFFFFF;
  --bg-tertiary: #E5E5EA;
  --bg-sidebar: #F8F8FA;
  --text-primary: #1C1C1E;
  --text-secondary: rgba(60, 60, 67, 0.6);
  --text-tertiary: rgba(60, 60, 67, 0.3);
  --text-on-accent: #FFFFFF;
  --separator: rgba(60, 60, 67, 0.18);
  --accent: #D97706;
  --accent-pressed: #B86200;
  --accent-soft: rgba(217, 119, 6, 0.12);
  --danger: #C43D3D;
  --danger-soft: rgba(196, 61, 61, 0.10);
  --info: #397EB9;
  --success: #2D8A5B;
  --macro-carbs: #388A5B;
  --macro-protein: #397EB9;
  --macro-fat: #A96E20;
  --overlay: rgba(0, 0, 0, 0.48);
  --shadow: rgba(0, 0, 0, 0.10);
}

page {
  background: var(--bg-primary);
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

.page { min-height: 100vh; padding: 24rpx 28rpx 40rpx; box-sizing: border-box; background: var(--bg-primary); color: var(--text-primary); }
.section { margin-bottom: 28rpx; }
.section-title { color: var(--text-primary); font-size: 30rpx; font-weight: 700; margin-bottom: 14rpx; }
.card { background: var(--bg-secondary); border: 1rpx solid var(--separator); border-radius: 12rpx; padding: 24rpx; box-shadow: 0 8rpx 24rpx var(--shadow); }
.row { display: flex; align-items: center; gap: 16rpx; }
.grow { flex: 1; min-width: 0; }
.muted { color: var(--text-secondary); }
.small { font-size: 24rpx; }
.strong { color: var(--text-primary); font-weight: 700; }
.empty { padding: 56rpx 24rpx; text-align: center; color: var(--text-secondary); }
.divider { height: 1rpx; background: var(--separator); margin: 20rpx 0; }

button { border-radius: 10rpx; font-size: 28rpx; letter-spacing: 0; }
button::after { border: 0; }
.btn { min-height: 84rpx; display: flex; align-items: center; justify-content: center; padding: 0 28rpx; }
.btn-primary { background: var(--accent); color: var(--text-on-accent); font-weight: 700; }
.btn-primary:active { background: var(--accent-pressed); }
.btn-secondary { background: transparent; color: var(--text-secondary); border: 1rpx solid var(--separator); }
.btn-danger { background: var(--danger-soft); color: var(--danger); border: 1rpx solid var(--danger-soft); }
.btn-icon { width: 72rpx; height: 72rpx; min-height: 72rpx; padding: 0; display: flex; align-items: center; justify-content: center; }
.btn-small { min-height: 60rpx; padding: 0 18rpx; font-size: 24rpx; }

input, textarea, picker { box-sizing: border-box; color: var(--text-primary); }
input::placeholder, textarea::placeholder, .input-placeholder { color: var(--text-tertiary); }
.input, .textarea, .picker-field { width: 100%; min-height: 82rpx; background: var(--bg-tertiary); color: var(--text-primary); border: 1rpx solid var(--separator); border-radius: 10rpx; padding: 18rpx 22rpx; }
.textarea { min-height: 150rpx; }
.field { margin-bottom: 22rpx; }
.field-label { display: block; color: var(--text-secondary); font-size: 24rpx; margin-bottom: 8rpx; }
.form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }

.segments { display: flex; padding: 6rpx; background: var(--bg-tertiary); border-radius: 10rpx; margin-bottom: 24rpx; }
.segment { flex: 1; text-align: center; padding: 16rpx 8rpx; color: var(--text-secondary); border-radius: 8rpx; }
.segment.active { background: var(--bg-secondary); color: var(--accent); font-weight: 700; box-shadow: 0 3rpx 10rpx var(--shadow); }
.filter-scroll { white-space: nowrap; margin-bottom: 20rpx; }
.filter-chip { display: inline-flex; align-items: center; min-height: 60rpx; padding: 0 22rpx; margin-right: 12rpx; border: 1rpx solid var(--separator); border-radius: 30rpx; background: var(--bg-secondary); color: var(--text-secondary); }
.filter-chip.active { background: var(--accent); border-color: var(--accent); color: var(--text-on-accent); }

.list-row { display: flex; align-items: center; gap: 16rpx; padding: 22rpx 0; border-bottom: 1rpx solid var(--separator); }
.list-row:last-child { border-bottom: 0; }
.badge { display: inline-block; padding: 4rpx 12rpx; border-radius: 20rpx; background: var(--accent-soft); color: var(--accent); font-size: 22rpx; }
.swatch { width: 64rpx; height: 64rpx; flex: 0 0 64rpx; border-radius: 8rpx; display: flex; align-items: center; justify-content: center; background: var(--accent-soft); color: var(--accent); font-weight: 800; }

.modal-mask { position: fixed; inset: 0; z-index: 1000; display: flex; align-items: flex-end; background: var(--overlay); }
.modal-sheet { width: 100%; max-height: 88vh; overflow: auto; box-sizing: border-box; padding: 26rpx 28rpx calc(32rpx + env(safe-area-inset-bottom)); background: var(--bg-secondary); color: var(--text-primary); border-radius: 16rpx 16rpx 0 0; box-shadow: 0 -16rpx 48rpx var(--shadow); }
.modal-head { display: flex; align-items: center; gap: 16rpx; margin-bottom: 22rpx; }
.modal-title { flex: 1; font-size: 34rpx; font-weight: 800; }
.toast-note { padding: 18rpx 20rpx; border-radius: 10rpx; background: var(--accent-soft); color: var(--accent); font-size: 24rpx; }
