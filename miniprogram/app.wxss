page {
  --green: #2f855a;
  --green-dark: #236b48;
  --green-soft: #e9f5ee;
  --red: #d64545;
  --orange: #d97706;
  --blue: #2563a8;
  --bg: #f4f6f8;
  --surface: #ffffff;
  --text: #17201a;
  --muted: #6f7972;
  --line: #dfe5e1;
  background: var(--bg);
  color: var(--text);
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
}

.page { min-height: 100vh; padding: 24rpx 28rpx 40rpx; box-sizing: border-box; }
.page.dark { --bg:#0d1110; --surface:#171d1a; --text:#f2f6f3; --muted:#9ca7a0; --line:#303934; }
.section { margin-bottom: 28rpx; }
.section-title { font-size: 30rpx; font-weight: 700; margin-bottom: 14rpx; }
.card { background: var(--surface); border: 1rpx solid var(--line); border-radius: 12rpx; padding: 24rpx; }
.row { display: flex; align-items: center; gap: 16rpx; }
.grow { flex: 1; min-width: 0; }
.muted { color: var(--muted); }
.small { font-size: 24rpx; }
.strong { font-weight: 700; }
.empty { padding: 56rpx 24rpx; text-align: center; color: var(--muted); }
.divider { height: 1rpx; background: var(--line); margin: 20rpx 0; }

button { border-radius: 10rpx; font-size: 28rpx; letter-spacing: 0; }
button::after { border: 0; }
.btn { min-height: 84rpx; display:flex; align-items:center; justify-content:center; padding: 0 28rpx; }
.btn-primary { background: var(--green); color: #fff; font-weight: 700; }
.btn-secondary { background: var(--surface); color: var(--text); border: 1rpx solid var(--line); }
.btn-danger { background: #fff1f1; color: var(--red); border: 1rpx solid #f1cccc; }
.btn-icon { width: 72rpx; height: 72rpx; min-height: 72rpx; padding: 0; display:flex; align-items:center; justify-content:center; }
.btn-small { min-height: 60rpx; padding: 0 18rpx; font-size: 24rpx; }

input, textarea, picker { box-sizing: border-box; }
.input, .textarea, .picker-field { width:100%; min-height:82rpx; background:var(--surface); color:var(--text); border:1rpx solid var(--line); border-radius:10rpx; padding:18rpx 22rpx; }
.textarea { min-height: 150rpx; }
.field { margin-bottom: 22rpx; }
.field-label { display:block; color:var(--muted); font-size:24rpx; margin-bottom:8rpx; }
.form-grid { display:grid; grid-template-columns:1fr 1fr; gap:16rpx; }

.segments { display:flex; padding:6rpx; background:#e8ece9; border-radius:10rpx; margin-bottom:24rpx; }
.segment { flex:1; text-align:center; padding:16rpx 8rpx; color:var(--muted); border-radius:8rpx; }
.segment.active { background:#fff; color:var(--green-dark); font-weight:700; }
.filter-scroll { white-space:nowrap; margin-bottom:20rpx; }
.filter-chip { display:inline-flex; align-items:center; min-height:60rpx; padding:0 22rpx; margin-right:12rpx; border:1rpx solid var(--line); border-radius:30rpx; background:var(--surface); color:var(--muted); }
.filter-chip.active { background:var(--green); border-color:var(--green); color:#fff; }

.list-row { display:flex; align-items:center; gap:16rpx; padding:22rpx 0; border-bottom:1rpx solid var(--line); }
.list-row:last-child { border-bottom:0; }
.badge { display:inline-block; padding:4rpx 12rpx; border-radius:20rpx; background:var(--green-soft); color:var(--green-dark); font-size:22rpx; }
.swatch { width:64rpx; height:64rpx; flex:0 0 64rpx; border-radius:8rpx; display:flex; align-items:center; justify-content:center; background:#eaf4ee; color:var(--green-dark); font-weight:800; }

.modal-mask { position:fixed; inset:0; z-index:1000; display:flex; align-items:flex-end; background:rgba(0,0,0,.56); }
.modal-sheet { width:100%; max-height:88vh; overflow:auto; box-sizing:border-box; padding:26rpx 28rpx calc(32rpx + env(safe-area-inset-bottom)); background:var(--surface); border-radius:16rpx 16rpx 0 0; }
.modal-head { display:flex; align-items:center; gap:16rpx; margin-bottom:22rpx; }
.modal-title { flex:1; font-size:34rpx; font-weight:800; }

.toast-note { padding:18rpx 20rpx; border-radius:10rpx; background:#fff7e8; color:#8a5504; font-size:24rpx; }
