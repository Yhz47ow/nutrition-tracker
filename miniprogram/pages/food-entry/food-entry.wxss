.food-title,.amount-row,.quick-row,.recommend,.photo-actions{display:flex;align-items:center;gap:14rpx}.food-title{justify-content:space-between;margin-bottom:26rpx}.page-name{font-size:42rpx;font-weight:800}.amount-card{margin-bottom:18rpx}.amount-row{justify-content:center}.amount-input{width:180rpx;height:90rpx;color:var(--text-primary);text-align:center;font-size:52rpx;font-weight:800;border-bottom:2rpx solid var(--accent)}.unit{font-size:26rpx;color:var(--text-secondary)}.quick-row{justify-content:center;margin-top:18rpx}.recommend{margin-bottom:20rpx;color:var(--accent)}.macro-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10rpx;margin-bottom:28rpx}.macro-grid>view{background:var(--bg-secondary);border:1rpx solid var(--separator);padding:18rpx 8rpx;border-radius:10rpx;text-align:center;display:flex;flex-direction:column}.macro-number{font-size:32rpx;font-weight:800}.meal-options{display:grid;grid-template-columns:repeat(4,1fr);gap:10rpx}.meal-option{padding:20rpx 4rpx;text-align:center;border:1rpx solid var(--separator);background:var(--bg-secondary);border-radius:10rpx}.meal-option.active{background:var(--accent);color:var(--text-on-accent);border-color:var(--accent)}.photo{width:130rpx;height:130rpx;border-radius:10rpx}.save{margin-top:26rpx}
