<view class="page {{themeClass}}" wx:if="{{food}}">
  <view class="food-title"><view><view class="page-name">{{food.name}}</view><view class="small muted">每100g · {{food.caloriesPer100g}} kcal</view></view><text class="badge">{{food.source==='custom'?'自定义':food.source==='api'?'联网':'内置'}}</text></view>
  <view class="card amount-card"><view class="field-label">食用克数</view><view class="amount-row"><button class="btn-icon btn-secondary" data-delta="-10" bindtap="adjustGrams">−</button><input class="amount-input" type="digit" value="{{grams}}" bindinput="inputGrams"/><text class="unit">g</text><button class="btn-icon btn-secondary" data-delta="10" bindtap="adjustGrams">＋</button></view><view class="quick-row"><button class="btn-small btn-secondary" data-delta="-50" bindtap="adjustGrams">−50</button><button class="btn-small btn-secondary" data-delta="50" bindtap="adjustGrams">+50</button><button class="btn-small btn-secondary" data-delta="100" bindtap="adjustGrams">+100</button></view></view>
  <view class="recommend card" wx:if="{{recommendation.grams}}" bindtap="useRecommendation"><view class="grow"><view class="strong">推荐 {{recommendation.grams}}g</view><view class="small muted">{{recommendation.reason}}，点击采用</view></view><text>采用</text></view>
  <view class="macro-grid" wx:if="{{macros}}"><view><text>热量</text><text class="macro-number">{{macros.calories}}</text><text class="small muted">kcal</text></view><view><text>碳水</text><text class="macro-number">{{macros.carbs}}</text><text class="small muted">g</text></view><view><text>蛋白</text><text class="macro-number">{{macros.protein}}</text><text class="small muted">g</text></view><view><text>脂肪</text><text class="macro-number">{{macros.fat}}</text><text class="small muted">g</text></view></view>
  <view class="section"><view class="section-title">选择餐次</view><view class="meal-options"><view class="meal-option {{meal===item.type?'active':''}}" wx:for="{{mealOptions}}" wx:key="type" data-meal="{{item.type}}" bindtap="selectMeal">{{item.name}}</view></view></view>
  <view class="section"><view class="section-title">食物照片</view><view class="photo-actions"><image wx:if="{{photo}}" class="photo" src="{{photo}}" mode="aspectFill"></image><button class="btn btn-secondary grow" bindtap="choosePhoto">{{photo?'更换照片':'拍照或选择照片'}}</button><button wx:if="{{photo}}" class="btn-icon btn-danger" bindtap="removePhoto">删</button></view></view>
  <view class="toast-note">记录日期：{{date}}</view>
  <button class="btn btn-primary save" bindtap="save">保存到{{meal==='breakfast'?'早餐':meal==='lunch'?'午餐':meal==='dinner'?'晚餐':'加餐'}}</button>
</view>
