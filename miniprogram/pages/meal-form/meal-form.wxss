.search-results{margin-top:10rpx;padding:0 20rpx;background:var(--bg-secondary);border:1rpx solid var(--separator);border-radius:10rpx}.add-mark{color:var(--accent);font-size:38rpx}.component-title{margin-top:28rpx}.component-list{padding-top:0;padding-bottom:0}.component-row{display:flex;align-items:center;gap:12rpx;padding:18rpx 0;border-bottom:1rpx solid var(--separator)}.component-row:last-child{border-bottom:0}.grams-input{width:120rpx;height:66rpx;text-align:center;background:var(--bg-tertiary);border:1rpx solid var(--separator);border-radius:8rpx}.total-card{display:grid;grid-template-columns:repeat(2,1fr);gap:16rpx;margin-top:20rpx}.total-card>view{display:flex;justify-content:space-between}.save{margin-top:24rpx}
