.today-head,.cycle-day-head,.target-preview{display:flex;align-items:center;justify-content:space-between;gap:12rpx}.enable-options,.repeat-options{margin-bottom:20rpx}.target-preview{min-height:58rpx;margin:4rpx 0 14rpx;padding:0 14rpx;border-radius:8rpx;font-size:22rpx}.target-preview.valid{background:var(--accent-soft);color:var(--accent)}.target-preview.invalid{background:var(--danger-soft);color:var(--danger)}.apply-all{margin-top:4rpx}.cycle-day{margin-bottom:18rpx;padding:20rpx;background:var(--bg-secondary);border:1rpx solid var(--separator);border-radius:10rpx}.cycle-day-head{margin-bottom:16rpx}.day-index{width:50rpx;height:50rpx;display:flex;align-items:center;justify-content:center;border-radius:8rpx;background:var(--accent-soft);color:var(--accent);font-weight:800}.day-name{flex:1;height:64rpx;color:var(--text-primary);border-bottom:1rpx solid var(--separator)}.cycle-day .field{margin-bottom:8rpx}.save-plan{margin-top:6rpx}
