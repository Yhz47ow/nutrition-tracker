<view class="page {{themeClass}}" wx:if="{{cycle}}">
  <view class="section"><view class="section-title">今日临时目标</view><view class="today-head"><view><view class="strong">{{today}}</view><view class="small muted">{{hasTodayOverride?'已覆盖周期计划':'仅修改今天'}}</view></view><button class="btn btn-small btn-secondary" wx:if="{{hasTodayOverride}}" bindtap="clearToday">恢复计划</button></view><view class="form-grid"><view class="field"><text class="field-label">热量 kcal</text><input class="input" type="digit" value="{{todayForm.calories}}" data-field="calories" bindinput="inputToday"/></view><view class="field"><text class="field-label">碳水 %</text><input class="input" type="digit" value="{{todayForm.carbs}}" data-field="carbs" bindinput="inputToday"/></view><view class="field"><text class="field-label">蛋白质 %</text><input class="input" type="digit" value="{{todayForm.protein}}" data-field="protein" bindinput="inputToday"/></view><view class="field"><text class="field-label">脂肪 %</text><input class="input" type="digit" value="{{todayForm.fat}}" data-field="fat" bindinput="inputToday"/></view></view><view class="target-preview {{todayTotal===100?'valid':'invalid'}}"><text>比例 {{todayTotal}}%</text><text>{{todayTargets.carbs}}g 碳水 · {{todayTargets.protein}}g 蛋白 · {{todayTargets.fat}}g 脂肪</text></view><button class="btn btn-secondary" bindtap="saveToday">仅保存今天</button></view>
  <view class="section strategy-section"><view wx:if="{{strategyMode==='532-taper'}}"><view class="strategy-heading"><view><view class="section-title">532 碳水渐降</view><view class="small muted">自动生成周期目标</view></view><text class="recommend-badge">推荐</text></view><view class="method-summary">首阶段按50%碳水、30%蛋白质、20%脂肪分配，后续保持蛋白质和脂肪不变，仅逐阶段降低碳水。</view><view class="form-grid"><view class="field"><text class="field-label">起始热量 kcal</text><input class="input" type="number" value="{{taperForm.startCalories}}" data-field="startCalories" bindinput="inputTaper"/></view><view class="field"><text class="field-label">每阶段天数</text><input class="input" type="number" value="{{taperForm.stageDays}}" data-field="stageDays" bindinput="inputTaper"/></view><view class="field"><text class="field-label">阶段数量</text><input class="input" type="number" value="{{taperForm.stageCount}}" data-field="stageCount" bindinput="inputTaper"/></view><view class="field"><text class="field-label">每阶段减少碳水 g</text><input class="input" type="digit" value="{{taperForm.carbDrop}}" data-field="carbDrop" bindinput="inputTaper"/></view></view><view class="method-error" wx:if="{{taperPreview.error}}">{{taperPreview.error}}</view><view class="taper-preview" wx:else><view><text class="preview-label">第1阶段</text><text class="preview-value">{{taperPreview.firstCalories}} kcal</text><text class="preview-macros">碳 {{taperPreview.baseTargets.carbs}}g · 蛋 {{taperPreview.baseTargets.protein}}g · 脂 {{taperPreview.baseTargets.fat}}g</text></view><view class="preview-arrow">→</view><view><text class="preview-label">最后阶段</text><text class="preview-value">{{taperPreview.lastCalories}} kcal</text><text class="preview-macros">碳 {{taperPreview.lastTargets.carbs}}g · 蛋 {{taperPreview.lastTargets.protein}}g · 脂 {{taperPreview.lastTargets.fat}}g</text></view></view><button class="btn btn-primary generate-btn" bindtap="generateTaper">生成后续 {{taperPreview.cycleLength||0}} 天</button><button class="btn btn-secondary mode-switch" data-value="manual" bindtap="setStrategy">改为自由设置</button></view><view wx:else><view class="strategy-heading"><view><view class="section-title">自由设置</view><view class="small muted">手动编辑每一天的摄入目标</view></view></view><view class="manual-hint muted">在下方调整周期天数，再逐日填写热量和营养比例。</view><button class="btn btn-secondary mode-switch" data-value="532-taper" bindtap="setStrategy">使用 532 碳水渐降自动生成</button></view></view>
  <view class="section"><view class="section-title">周期设置</view><view class="segments enable-options"><view class="segment {{enabled?'active':''}}" data-value="true" bindtap="setEnabled">启用</view><view class="segment {{!enabled?'active':''}}" data-value="false" bindtap="setEnabled">停用</view></view><view class="field"><text class="field-label">计划名称</text><input class="input" value="{{cycle.name}}" data-field="name" bindinput="inputMeta"/></view><view class="form-grid"><view class="field"><text class="field-label">开始日期</text><picker mode="date" value="{{cycle.startDate}}" bindchange="changeStartDate"><view class="picker-field">{{cycle.startDate}}</view></picker></view><view class="field"><text class="field-label">周期天数（1-31）</text><input class="input" type="number" value="{{cycle.cycleLength}}" bindblur="changeLength"/></view></view><view class="segments repeat-options"><view class="segment {{cycle.repeat?'active':''}}" data-value="true" bindtap="setRepeat">循环</view><view class="segment {{!cycle.repeat?'active':''}}" data-value="false" bindtap="setRepeat">单次</view></view><button class="btn btn-secondary apply-all" bindtap="applyFirstToAll">将第1天参数应用到全部</button></view>
  <view class="section"><view class="section-title">每日目标</view><view class="cycle-day" wx:for="{{dayRows}}" wx:key="index"><view class="cycle-day-head"><text class="day-index">{{item.index}}</text><input class="day-name" value="{{item.name}}" data-index="{{index}}" data-field="name" bindinput="inputDay"/></view><view class="form-grid"><view class="field"><text class="field-label">热量 kcal</text><input class="input" type="digit" value="{{item.calories}}" data-index="{{index}}" data-field="calories" bindinput="inputDay"/></view><view class="field"><text class="field-label">碳水 %</text><input class="input" type="digit" value="{{item.carbs}}" data-index="{{index}}" data-field="carbs" bindinput="inputDay"/></view><view class="field"><text class="field-label">蛋白质 %</text><input class="input" type="digit" value="{{item.protein}}" data-index="{{index}}" data-field="protein" bindinput="inputDay"/></view><view class="field"><text class="field-label">脂肪 %</text><input class="input" type="digit" value="{{item.fat}}" data-index="{{index}}" data-field="fat" bindinput="inputDay"/></view></view><view class="target-preview {{item.total===100?'valid':'invalid'}}"><text>比例 {{item.total}}%</text><text>{{item.targets.carbs}}g · {{item.targets.protein}}g · {{item.targets.fat}}g</text></view></view></view>
  <button class="btn btn-primary save-plan" bindtap="save">保存周期计划</button>
</view>
