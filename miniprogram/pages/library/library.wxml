<view class="page {{themeClass}}">
  <view class="toolbar"><input class="input grow" value="{{query}}" placeholder="搜索名称或拼音首字母" bindinput="inputQuery"/><button class="btn-icon btn-primary" wx:if="{{tab!=='template'}}" bindtap="newFood">＋</button><button class="btn-icon btn-primary" wx:else bindtap="newTemplate">＋</button></view>
  <view class="segments"><view class="segment {{tab==='builtin'?'active':''}}" data-tab="builtin" bindtap="switchTab">内置食物</view><view class="segment {{tab==='custom'?'active':''}}" data-tab="custom" bindtap="switchTab">我的食物</view><view class="segment {{tab==='template'?'active':''}}" data-tab="template" bindtap="switchTab">我的套餐</view></view>
  <scroll-view wx:if="{{tab!=='template'}}" class="filter-scroll" scroll-x><view class="filter-chip {{category===item.key?'active':''}}" wx:for="{{categories}}" wx:key="key" data-category="{{item.key}}" bindtap="setCategory">{{item.label}}</view></scroll-view>
  <block wx:if="{{tab!=='template'}}"><view class="empty" wx:if="{{!foods.length}}">暂无食物</view><view class="card list" wx:else><view class="list-row" wx:for="{{foods}}" wx:key="id"><view class="grow"><view class="title-line"><view class="strong">{{item.name}}</view><text class="badge">{{item.categoryLabel}}</text></view><view class="small muted">每100g · {{item.caloriesPer100g}}kcal · 蛋{{item.proteinPer100g}} 脂{{item.fatPer100g}} 碳{{item.carbsPer100g}}</view></view><button class="favorite {{item.favorite?'active':''}}" data-id="{{item.id}}" bindtap="toggleFavorite">{{item.favorite?'★':'☆'}}</button><button wx:if="{{tab==='custom'}}" class="btn-icon btn-small btn-secondary" data-id="{{item.id}}" bindtap="editFood">改</button><button wx:if="{{tab==='custom'}}" class="btn-icon btn-small btn-danger" data-id="{{item.id}}" bindtap="deleteFood">删</button><button class="btn-icon btn-small btn-secondary" data-id="{{item.id}}" bindtap="addFood">＋</button></view></view></block>
  <block wx:else><view class="empty" wx:if="{{!templates.length}}">暂无套餐，点击右上角创建</view><view class="card list" wx:else><view class="list-row" wx:for="{{templates}}" wx:key="id"><view class="grow"><view class="strong">{{item.name}}</view><view class="small muted">{{item.components.length}} 种 · {{item.totals.grams}}g · {{item.totals.calories}}kcal</view></view><button class="btn-icon btn-small btn-secondary" data-id="{{item.id}}" bindtap="editTemplate">改</button><button class="btn-icon btn-small btn-danger" data-id="{{item.id}}" bindtap="deleteTemplate">删</button></view></view></block>
</view>
