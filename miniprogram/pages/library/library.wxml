<view class="page {{themeClass}}">
  <view class="toolbar"><input class="input grow" value="{{query}}" placeholder="查找食材、菜肴或拼音首字母" bindinput="inputQuery"/><button class="btn-icon btn-primary" wx:if="{{tab==='favorite'||tab==='builtin'||tab==='custom'}}" bindtap="newFood">＋</button><button class="btn-icon btn-primary" wx:if="{{tab==='template'}}" bindtap="newTemplate">＋</button></view>
  <scroll-view class="library-tabs" scroll-x><view class="library-tab {{tab==='favorite'?'active':''}}" data-tab="favorite" bindtap="switchTab">常用</view><view class="library-tab {{tab==='builtin'?'active':''}}" data-tab="builtin" bindtap="switchTab">基础食材</view><view class="library-tab {{tab==='dish'?'active':''}}" data-tab="dish" bindtap="switchTab">家常菜</view><view class="library-tab {{tab==='custom'?'active':''}}" data-tab="custom" bindtap="switchTab">我的食物</view><view class="library-tab {{tab==='template'?'active':''}}" data-tab="template" bindtap="switchTab">我的套餐</view></scroll-view>
  <scroll-view wx:if="{{tab==='favorite'||tab==='builtin'||tab==='custom'}}" class="filter-scroll" scroll-x><view class="filter-chip {{category===item.key?'active':''}}" wx:for="{{categories}}" wx:key="key" data-category="{{item.key}}" bindtap="setCategory">{{item.label}}</view></scroll-view>
  <block wx:if="{{tab==='dish'}}"><view class="empty" wx:if="{{!dishes.length}}">没有匹配的家常菜</view><view class="card list" wx:else><view class="list-row dish-row" wx:for="{{dishes}}" wx:key="id" data-id="{{item.id}}" bindtap="selectDish"><view class="swatch">菜</view><view class="grow"><view class="strong">{{item.name}}</view><view class="small muted">{{item.ingredientCount}} 种食材 · 整道约 {{item.totals.calories}} kcal</view><view class="small muted">建议食用 {{item.suggestedServing}}g</view></view><text class="row-go">调整 ›</text></view></view></block>
  <block wx:elif="{{tab==='template'}}"><view class="empty" wx:if="{{!templates.length}}">暂无套餐，点击右上角创建</view><view class="card list" wx:else><view class="list-row" wx:for="{{templates}}" wx:key="id"><view class="grow"><view class="strong">{{item.name}}</view><view class="small muted">{{item.components.length}} 种 · {{item.totals.grams}}g · {{item.totals.calories}}kcal</view></view><button class="btn-small btn-primary" data-id="{{item.id}}" bindtap="recordTemplate">记录</button><button class="btn-icon btn-small btn-secondary" data-id="{{item.id}}" bindtap="editTemplate">改</button><button class="btn-icon btn-small btn-danger" data-id="{{item.id}}" bindtap="deleteTemplate">删</button></view></view></block>
  <block wx:else><view class="empty" wx:if="{{!foods.length}}">{{tab==='favorite'?'还没有常用食物，点击星标收藏':'暂无食物'}}</view><view class="card list" wx:else><view class="list-row" wx:for="{{foods}}" wx:key="id"><view class="grow"><view class="title-line"><view class="strong">{{item.name}}</view><text class="badge">{{item.categoryLabel}}</text></view><view class="small muted">每100g · {{item.caloriesPer100g}}kcal · 蛋{{item.proteinPer100g}} 脂{{item.fatPer100g}} 碳{{item.carbsPer100g}}</view></view><button class="favorite {{item.favorite?'active':''}}" data-id="{{item.id}}" bindtap="toggleFavorite">{{item.favorite?'★':'☆'}}</button><button wx:if="{{tab==='custom'}}" class="btn-icon btn-small btn-secondary" data-id="{{item.id}}" bindtap="editFood">改</button><button wx:if="{{tab==='custom'}}" class="btn-icon btn-small btn-danger" data-id="{{item.id}}" bindtap="deleteFood">删</button><button class="btn-icon btn-small btn-secondary" data-id="{{item.id}}" bindtap="addFood">＋</button></view></view></block>
</view>
