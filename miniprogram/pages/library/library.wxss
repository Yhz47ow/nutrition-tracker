.toolbar{display:flex;gap:12rpx;margin-bottom:18rpx}.library-tabs{white-space:nowrap;margin-bottom:22rpx;padding-bottom:2rpx}.library-tab{display:inline-flex;align-items:center;justify-content:center;min-height:68rpx;padding:0 22rpx;margin-right:8rpx;color:var(--text-secondary);border-bottom:4rpx solid transparent}.library-tab.active{color:var(--accent);font-weight:700;border-bottom-color:var(--accent)}.list{padding-top:0;padding-bottom:0}.title-line{display:flex;align-items:center;gap:10rpx;margin-bottom:5rpx}.favorite{width:58rpx;height:58rpx;min-height:58rpx;padding:0;background:transparent;color:var(--text-tertiary);font-size:38rpx}.favorite.active{color:var(--accent)}.dish-row{min-height:116rpx}.row-go{color:var(--accent);white-space:nowrap}
