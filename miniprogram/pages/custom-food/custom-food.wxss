.identity-fields{display:grid;grid-template-columns:1fr;gap:0}.unit-input{display:flex;align-items:center;gap:14rpx}.unit-input .input{flex:1}.unit-input>text{width:36rpx;color:var(--text-secondary)}.energy-field{margin-bottom:24rpx;padding:22rpx;background:var(--bg-secondary);border:1rpx solid var(--separator);border-radius:10rpx}.energy-units{display:grid;grid-template-columns:1fr 1fr;gap:8rpx;padding:6rpx;margin-bottom:14rpx;background:var(--bg-tertiary);border-radius:9rpx}.energy-unit{min-height:68rpx;display:flex;align-items:center;justify-content:center;color:var(--text-secondary);border-radius:7rpx}.energy-unit.active{background:var(--accent);color:var(--text-on-accent);font-weight:700}.energy-input{margin-top:2rpx}.energy-help{display:flex;flex-direction:column;gap:6rpx;margin-top:12rpx;color:var(--text-secondary);font-size:23rpx}.conversion{color:var(--accent);font-weight:700}.calculator{margin:10rpx 0 24rpx}.actual{margin-top:16rpx;color:var(--accent);font-weight:700}.save{margin-top:20rpx}@media (max-width:360px){.nutrition-grid{grid-template-columns:1fr}}
