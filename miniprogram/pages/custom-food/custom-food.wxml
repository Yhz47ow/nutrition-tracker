<view class="page {{themeClass}}"><view class="field"><text class="field-label">食物名称 *</text><input class="input" value="{{form.name}}" data-field="name" bindinput="inputField" placeholder="例如：某品牌蛋白棒"/></view><view class="form-grid"><view class="field"><text class="field-label">单位</text><input class="input" value="{{form.unit}}" data-field="unit" bindinput="inputField"/></view><view class="field"><text class="field-label">参考份量</text><input class="input" type="digit" value="{{form.servingSize}}" data-field="servingSize" bindinput="inputField"/></view></view><view class="section-title">每 100g 营养</view><view class="form-grid"><view class="field"><text class="field-label">热量 kcal</text><input class="input" type="digit" value="{{form.caloriesPer100g}}" data-field="caloriesPer100g" bindinput="inputField"/></view><view class="field"><text class="field-label">碳水 g</text><input class="input" type="digit" value="{{form.carbsPer100g}}" data-field="carbsPer100g" bindinput="inputField"/></view><view class="field"><text class="field-label">蛋白质 g</text><input class="input" type="digit" value="{{form.proteinPer100g}}" data-field="proteinPer100g" bindinput="inputField"/></view><view class="field"><text class="field-label">脂肪 g</text><input class="input" type="digit" value="{{form.fatPer100g}}" data-field="fatPer100g" bindinput="inputField"/></view></view><view class="card calculator"><view class="section-title">包装份量计算</view><input class="input" type="digit" value="{{actualAmount}}" bindinput="inputActual" placeholder="输入实际吃了多少克"/><view class="actual" wx:if="{{actualResult}}">{{actualResult.calories}} kcal · 碳{{actualResult.carbs}}g · 蛋{{actualResult.protein}}g · 脂{{actualResult.fat}}g</view></view><button class="btn btn-primary save" bindtap="save">保存食物</button></view>
