<view class="page {{themeClass}}"><view class="field"><text class="field-label">动作名称 *</text><input class="input" value="{{name}}" bindinput="inputName" placeholder="例如：地雷管划船"/></view><view class="field"><text class="field-label">肌群分类 *</text><picker mode="selector" range="{{parts}}" bindchange="choosePart"><view class="picker-field">{{bodyPart}}</view></picker></view><view class="field"><text class="field-label">备注</text><textarea class="textarea" value="{{note}}" bindinput="inputNote" placeholder="器械设置、动作提示等"></textarea></view><button class="btn btn-primary" bindtap="save">保存动作</button></view>
