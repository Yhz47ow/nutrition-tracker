page{background:#0d1110}.training-page{padding-bottom:180rpx}.training-head,.rest-setting,.picker-tools,.bottom-actions,.finish-summary{display:flex;align-items:center;gap:14rpx}.training-head{margin-bottom:20rpx}.training-title{font-size:42rpx;font-weight:850}.dark-icon{width:72rpx;height:72rpx;min-height:72rpx;padding:0;background:#242d28;color:#fff;border:1rpx solid #3a463f}.dark-icon.danger{color:#ff9d9d}.finish-link{min-height:72rpx;padding:0 20rpx;background:#442529;color:#ffb0b0}.exercise-strip{white-space:nowrap;margin-bottom:22rpx}.exercise-chip{display:inline-flex;align-items:center;min-height:66rpx;padding:0 22rpx;margin-right:12rpx;border:1rpx solid #3a463f;border-radius:33rpx;color:#abb6af;background:#171d1a}.exercise-chip.active{background:#62d692;color:#07130c;border-color:#62d692;font-weight:800}.exercise-chip.add{color:#62d692}.rest-setting{margin-bottom:28rpx}.set-label{text-align:center;color:#aab6af;font-size:26rpx;margin-bottom:14rpx}.set-controls{display:grid;grid-template-columns:1fr 1fr;gap:14rpx}.number-panel{background:#171d1a;border:1rpx solid #303934;border-radius:12rpx;padding:22rpx}.number-input{height:120rpx;color:#fff;text-align:center;font-size:62rpx;font-weight:850}.quick{display:grid;grid-template-columns:repeat(3,1fr);gap:8rpx}.quick button{min-height:64rpx;padding:0;background:#27312b;color:#fff;font-size:24rpx}.complete-set,.next-set{width:100%;min-height:104rpx;margin-top:22rpx;background:#62d692;color:#07130c;font-size:34rpx;font-weight:850}.dark-empty{color:#abb6af}.bottom-actions{position:fixed;left:0;right:0;bottom:0;padding:16rpx 28rpx calc(16rpx + env(safe-area-inset-bottom));background:#111714;border-top:1rpx solid #303934;z-index:100}.bottom-actions button{flex:1}.rest-mask{position:fixed;inset:0;z-index:900;background:rgba(6,10,8,.97);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40rpx}.rest-label{font-size:34rpx;font-weight:800;margin-bottom:32rpx}.rest-ring{width:410rpx;height:410rpx;border-radius:50%;padding:24rpx;box-sizing:border-box}.rest-inner{width:100%;height:100%;border-radius:50%;background:#111714;display:flex;flex-direction:column;align-items:center;justify-content:center}.rest-number{font-size:150rpx;font-weight:900}.rest-status{margin:30rpx 0;color:#abb6af}.rest-actions{display:grid;grid-template-columns:repeat(3,1fr);gap:14rpx;width:100%}.rest-actions button,.rest-finish{min-height:80rpx;background:#242d28;color:#fff}.rest-finish{margin-top:18rpx;color:#ffb0b0}.dark-sheet{background:#171d1a;color:#fff}.picker-tools{margin-bottom:16rpx}.picker-group-title{padding:18rpx 0;color:#62d692;font-weight:800}.picker-row{display:flex;align-items:center;gap:16rpx;padding:20rpx 0;border-bottom:1rpx solid #303934}.picker-submit{position:sticky;bottom:0}.finish-summary{justify-content:space-between;background:#242d28;padding:20rpx;border-radius:10rpx;margin-bottom:22rpx}
