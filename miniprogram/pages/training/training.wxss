.training-page{padding-bottom:180rpx}.training-head,.rest-setting,.picker-tools,.bottom-actions,.finish-summary{display:flex;align-items:center;gap:14rpx}.training-head{margin-bottom:20rpx}.training-title{font-size:42rpx;font-weight:850}.dark-icon{width:72rpx;height:72rpx;min-height:72rpx;padding:0;background:var(--bg-tertiary);color:var(--text-primary);border:1rpx solid var(--separator)}.dark-icon.danger{color:var(--danger)}.finish-link{min-height:72rpx;padding:0 20rpx;background:var(--danger-soft);color:var(--danger)}.exercise-strip{white-space:nowrap;margin-bottom:22rpx}.exercise-chip{display:inline-flex;align-items:center;min-height:66rpx;padding:0 22rpx;margin-right:12rpx;border:1rpx solid var(--separator);border-radius:33rpx;color:var(--text-secondary);background:var(--bg-secondary)}.exercise-chip.active{background:var(--accent);color:var(--text-on-accent);border-color:var(--accent);font-weight:800}.exercise-chip.add{color:var(--accent)}.rest-setting{margin-bottom:28rpx}.set-label{text-align:center;color:var(--text-secondary);font-size:26rpx;margin-bottom:14rpx}.set-controls{display:grid;grid-template-columns:1fr 1fr;gap:14rpx}.number-panel{background:var(--bg-secondary);border:1rpx solid var(--separator);border-radius:12rpx;padding:22rpx}.number-input{height:120rpx;color:var(--text-primary);text-align:center;font-size:62rpx;font-weight:850}.quick{display:grid;grid-template-columns:repeat(3,1fr);gap:8rpx}.quick button{min-height:64rpx;padding:0;background:var(--bg-tertiary);color:var(--text-primary);font-size:24rpx}.complete-set,.next-set{width:100%;min-height:104rpx;margin-top:22rpx;background:var(--accent);color:var(--text-on-accent);font-size:34rpx;font-weight:850}.dark-empty{color:var(--text-secondary)}.bottom-actions{position:fixed;left:0;right:0;bottom:0;padding:16rpx 28rpx calc(16rpx + env(safe-area-inset-bottom));background:var(--bg-sidebar);border-top:1rpx solid var(--separator);z-index:100}.bottom-actions button{flex:1}.rest-mask{position:fixed;inset:0;z-index:900;background:var(--bg-primary);display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40rpx}.rest-label{font-size:34rpx;font-weight:800;margin-bottom:32rpx}.rest-ring{width:410rpx;height:410rpx;border-radius:50%;padding:24rpx;box-sizing:border-box}.rest-inner{width:100%;height:100%;border-radius:50%;background:var(--bg-sidebar);display:flex;flex-direction:column;align-items:center;justify-content:center}.rest-number{font-size:150rpx;font-weight:900}.rest-status{margin:30rpx 0;color:var(--text-secondary)}.rest-actions{display:grid;grid-template-columns:repeat(3,1fr);gap:14rpx;width:100%}.rest-actions button,.rest-finish{min-height:80rpx;background:var(--bg-tertiary);color:var(--text-primary);border:1rpx solid var(--separator)}.rest-finish{margin-top:18rpx;color:var(--danger)}.dark-sheet{background:var(--bg-secondary);color:var(--text-primary)}.picker-tools{margin-bottom:16rpx}.picker-group-title{padding:18rpx 0;color:var(--accent);font-weight:800}.picker-row{display:flex;align-items:center;gap:16rpx;padding:20rpx 0;border-bottom:1rpx solid var(--separator)}.picker-submit{position:sticky;bottom:0}.finish-summary{justify-content:space-between;background:var(--bg-tertiary);padding:20rpx;border-radius:10rpx;margin-bottom:22rpx}
