<view class="page {{themeClass}} training-page" wx:if="{{workout}}">
  <view class="training-head"><button class="dark-icon" bindtap="back">×</button><view class="grow"><view class="small muted">训练进行中 · {{elapsed}}</view><view class="training-title">{{currentExercise?currentExercise.exerciseName:'添加训练动作'}}</view></view><button class="finish-link" bindtap="openFinish">结束</button></view>
  <scroll-view class="exercise-strip" scroll-x><view class="exercise-chip {{item.active?'active':''}}" wx:for="{{exercises}}" wx:key="id" data-index="{{index}}" bindtap="switchExercise">{{item.name}} · {{item.completed}}组</view><view class="exercise-chip add" bindtap="openPicker">＋ 添加动作</view></scroll-view>
  <block wx:if="{{currentExercise}}"><view class="rest-setting card"><view class="grow"><view class="small muted">组间休息</view><view class="strong">{{currentExercise.restBetweenSets}} 秒</view></view><button class="dark-icon" data-delta="-15" bindtap="adjustRest">−</button><button class="dark-icon" data-delta="15" bindtap="adjustRest">＋</button><button class="dark-icon danger" bindtap="removeExercise">删</button></view><view class="set-label">第 {{currentSet?currentSet.setNumber:(currentExercise.sets.length+1)}} 组</view><view class="set-controls" wx:if="{{currentSet}}"><view class="number-panel"><view class="small muted">重量 kg</view><input class="number-input" type="digit" value="{{currentSet.weight}}" data-field="weight" bindinput="updateSet"/><view class="quick"><button data-field="weight" data-delta="-2.5" bindtap="adjustSet">−2.5</button><button data-field="weight" data-delta="2.5" bindtap="adjustSet">+2.5</button><button data-field="weight" data-delta="5" bindtap="adjustSet">+5</button></view></view><view class="number-panel"><view class="small muted">次数</view><input class="number-input" type="number" value="{{currentSet.reps}}" data-field="reps" bindinput="updateSet"/><view class="quick"><button data-field="reps" data-delta="-1" bindtap="adjustSet">−1</button><button data-field="reps" data-delta="1" bindtap="adjustSet">+1</button><button data-field="reps" data-delta="5" bindtap="adjustSet">+5</button></view></view></view><button class="complete-set" wx:if="{{currentSet}}" bindtap="completeSet">完成本组</button><view class="empty dark-empty" wx:else><view>本动作已完成 {{currentExercise.sets.length}} 组</view><button class="complete-set" bindtap="nextSet">添加下一组</button></view></block>
  <view class="empty dark-empty" wx:else><view>当前还没有训练动作</view><button class="complete-set" bindtap="openPicker">添加动作</button></view>
  <view class="bottom-actions"><button class="btn btn-secondary" bindtap="openPicker">＋ 添加动作</button><button class="btn btn-danger" bindtap="openFinish">结束训练</button></view>

  <view class="rest-mask" wx:if="{{restOpen}}"><view class="rest-label">{{restComplete?'休息结束':'组间休息'}}</view><view class="rest-ring" style="background:conic-gradient(var(--accent) {{restProgress}}deg,var(--bg-tertiary) 0deg)"><view class="rest-inner"><view class="rest-number">{{restSeconds}}</view><view class="small muted">秒</view></view></view><view class="rest-status">{{restComplete?'可以开始下一组':restPaused?'已暂停':'恢复呼吸，准备下一组'}}</view><button class="next-set" wx:if="{{restComplete}}" bindtap="nextSet">开始下一组</button><view class="rest-actions" wx:else><button bindtap="toggleTimer">{{restPaused?'继续':'暂停'}}</button><button bindtap="skipTimer">跳过</button><button bindtap="addTimer">+10秒</button></view><button class="rest-finish" bindtap="openFinish">结束本次训练</button></view>

  <view class="modal-mask" wx:if="{{pickerOpen}}"><view class="modal-sheet dark-sheet"><view class="modal-head"><view class="modal-title">添加训练动作</view><button class="dark-icon" bindtap="closePicker">×</button></view><view class="picker-tools"><input class="input grow" value="{{pickerQuery}}" placeholder="搜索动作或肌群" bindinput="inputPicker"/><button class="dark-icon" bindtap="newExercise">＋</button></view><scroll-view class="filter-scroll" scroll-x><view class="filter-chip {{pickerFilter===item?'active':''}}" wx:for="{{bodyParts}}" wx:key="*this" data-part="{{item}}" bindtap="setPickerFilter">{{item}}</view></scroll-view><checkbox-group bindchange="pickerSelectionChange"><view class="picker-group" wx:for="{{pickerGroups}}" wx:key="part" wx:for-item="group"><view class="picker-group-title">{{group.part}} · {{group.items.length}}</view><label class="picker-row" wx:for="{{group.items}}" wx:key="id" wx:for-item="exercise"><checkbox value="{{exercise.id}}" checked="{{exercise.checked}}" color="{{accent}}"/><view class="grow"><view class="strong">{{exercise.name}}</view><view class="small muted">{{exercise.note || exercise.bodyPart}}{{exercise.isCustom?' · 自定义':''}}</view></view></label></view></checkbox-group><button class="complete-set picker-submit" bindtap="confirmPicker">添加所选{{pickerSelection.length?'（'+pickerSelection.length+'）':''}}</button></view></view>

  <view class="modal-mask" wx:if="{{finishOpen}}" bindtap="closeFinish"><view class="modal-sheet dark-sheet" catchtap="noop"><view class="modal-head"><view class="modal-title">结束本次训练</view><button class="dark-icon" bindtap="closeFinish">×</button></view><view class="finish-summary"><text>{{exercises.length}} 个动作</text><text>{{elapsed}}</text></view><view class="field"><text class="field-label">训练备注</text><textarea class="textarea" value="{{finishNote}}" bindinput="inputFinishNote" placeholder="今天的状态、动作调整等"></textarea></view><button class="complete-set" bindtap="finish">保存并结束训练</button></view></view>
</view>
