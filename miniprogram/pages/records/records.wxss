.date-strip{white-space:nowrap;margin-bottom:22rpx}.date-chip{display:inline-flex;flex-direction:column;min-width:160rpx;padding:16rpx;margin-right:12rpx;border:1rpx solid var(--line);border-radius:10rpx;background:var(--surface)}.date-chip.active{background:var(--green);color:#fff;border-color:var(--green)}.record-total{display:flex;justify-content:space-between;margin-bottom:24rpx}.list{padding-top:0;padding-bottom:0}.photo{width:70rpx;height:70rpx;border-radius:8rpx}
