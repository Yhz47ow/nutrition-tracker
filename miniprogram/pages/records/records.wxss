.records-head{display:flex;align-items:center;justify-content:space-between;gap:16rpx;margin-bottom:24rpx}.records-title{font-size:40rpx;font-weight:800}.date-strip{white-space:nowrap;margin-bottom:22rpx}.date-chip{display:inline-flex;flex-direction:column;min-width:160rpx;padding:16rpx;margin-right:12rpx;border:1rpx solid var(--separator);border-radius:10rpx;background:var(--bg-secondary);color:var(--text-secondary)}.date-chip.active{background:var(--accent);color:var(--text-on-accent);border-color:var(--accent)}.record-total{display:flex;justify-content:space-between;margin-bottom:24rpx}.list{padding-top:0;padding-bottom:0}.photo{width:70rpx;height:70rpx;border-radius:8rpx}
