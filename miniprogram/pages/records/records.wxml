<view class="page {{themeClass}}">
  <view class="records-head"><view><view class="records-title">饮食记录</view><view class="small muted">按日期回顾摄入</view></view></view>
  <scroll-view class="date-strip" scroll-x wx:if="{{dates.length}}"><view class="date-chip {{selectedDate===item.key?'active':''}}" wx:for="{{dates}}" wx:key="key" data-date="{{item.key}}" bindtap="chooseDate"><text>{{item.label}}</text><text class="small">{{item.key}}</text></view></scroll-view>
  <view class="empty" wx:if="{{!summary}}">还没有饮食记录</view>
  <block wx:else><view class="record-total card"><text class="strong">{{summary.dateLabel}} · {{targetMode.label}}</text><text>{{summary.totals.calories}} / {{summary.targets.calories}} kcal · {{summary.totals.weight}}g · {{summary.totals.mealCount}} 餐</text></view><view class="section" wx:for="{{summary.meals}}" wx:key="type" wx:for-item="meal" wx:if="{{meal.items.length}}"><view class="section-title">{{meal.name}} · {{meal.calories}} kcal</view><view class="card list"><view class="list-row" wx:for="{{meal.items}}" wx:key="id" wx:for-item="food" wx:for-index="foodIndex"><image wx:if="{{food.photo}}" class="photo" src="{{food.photo}}" mode="aspectFill" data-path="{{food.photo}}" bindtap="previewPhoto"></image><view class="grow"><view class="strong">{{food.foodName || food.name}}</view><view class="small muted">{{food.grams}}g · 碳{{food.carbs}} 蛋{{food.protein}} 脂{{food.fat}}</view></view><text>{{food.calories}} kcal</text><button class="btn-icon btn-small btn-danger" data-meal="{{meal.type}}" data-index="{{foodIndex}}" bindtap="deleteItem">删</button></view></view></view><button class="btn btn-danger" bindtap="clearAll">清除全部饮食记录</button></block>
</view>
