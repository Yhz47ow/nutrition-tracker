<view class="page {{themeClass}}" wx:if="{{dish}}">
  <view class="dish-head"><view><view class="page-name">{{dish.name}}</view><view class="small muted">整道菜为本地配方估算，可按实际用量修改</view></view><button class="btn-small btn-secondary" bindtap="reset">重置</button></view>
  <view class="macro-grid" wx:if="{{totals}}"><view><text>总热量</text><text class="macro-number">{{totals.calories}}</text><text class="small muted">kcal</text></view><view><text>总重量</text><text class="macro-number">{{totals.grams}}</text><text class="small muted">g</text></view><view><text>蛋白质</text><text class="macro-number">{{totals.protein}}</text><text class="small muted">g</text></view><view><text>脂肪</text><text class="macro-number">{{totals.fat}}</text><text class="small muted">g</text></view><view><text>碳水</text><text class="macro-number">{{totals.carbs}}</text><text class="small muted">g</text></view><view><text>膳食纤维</text><text class="macro-number">{{totals.fiber}}</text><text class="small muted">g</text></view></view>
  <view class="suggested"><view class="grow"><view class="strong">建议食用 {{dish.suggestedServing}}g</view><view class="small muted">按比例缩放下面全部食材</view></view><button class="btn-small btn-secondary" bindtap="useSuggested">采用</button></view>
  <view class="section-title">食材分解</view><view class="ingredient-list"><view class="ingredient-row" wx:for="{{ingredients}}" wx:key="id"><view class="grow"><view class="strong">{{item.name}}</view><view class="small muted">{{item.categoryLabel}} · {{item.macros.calories}} kcal</view></view><button class="adjust" data-index="{{index}}" data-delta="-5" bindtap="adjustGrams">−</button><input class="grams-input" type="digit" value="{{item.grams}}" data-index="{{index}}" bindinput="inputGrams"/><text class="muted">g</text><button class="adjust" data-index="{{index}}" data-delta="5" bindtap="adjustGrams">＋</button></view></view>
  <view class="section"><view class="section-title">记录到</view><view class="meal-options"><view class="meal-option {{meal===item.type?'active':''}}" wx:for="{{mealOptions}}" wx:key="type" data-meal="{{item.type}}" bindtap="selectMeal">{{item.name}}</view></view></view>
  <view class="toast-note">保存后按食材拆分记录，膳食宝塔分类会分别计入，不会把整道菜归错类别。</view>
  <button class="btn btn-primary save" bindtap="save">保存这份{{dish.name}}</button>
</view>
