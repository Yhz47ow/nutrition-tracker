.dish-head,.suggested,.ingredient-row{display:flex;align-items:center;gap:12rpx}.dish-head{justify-content:space-between;margin-bottom:24rpx}.page-name{font-size:40rpx;font-weight:800}.macro-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10rpx;margin-bottom:20rpx}.macro-grid>view{display:flex;flex-direction:column;align-items:center;padding:18rpx 6rpx;background:var(--bg-secondary);border:1rpx solid var(--separator);border-radius:10rpx}.macro-number{font-size:32rpx;font-weight:800}.suggested{margin-bottom:28rpx;padding:20rpx;background:var(--accent-soft);border:1rpx solid var(--separator);border-radius:10rpx}.ingredient-list{margin-bottom:28rpx;border-top:1rpx solid var(--separator)}.ingredient-row{min-height:104rpx;border-bottom:1rpx solid var(--separator)}.grams-input{width:92rpx;height:64rpx;text-align:center;background:var(--bg-tertiary);border:1rpx solid var(--separator);border-radius:8rpx}.adjust{width:58rpx;height:58rpx;min-height:58rpx;padding:0;background:transparent;color:var(--text-primary);border:1rpx solid var(--separator)}.meal-options{display:grid;grid-template-columns:repeat(4,1fr);gap:10rpx}.meal-option{padding:20rpx 4rpx;text-align:center;border:1rpx solid var(--separator);background:var(--bg-secondary);border-radius:10rpx}.meal-option.active{background:var(--accent);color:var(--text-on-accent);border-color:var(--accent)}.save{margin-top:24rpx}
