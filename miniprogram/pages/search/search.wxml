<view class="page {{themeClass}}">
  <view class="search-row"><input class="input grow" value="{{query}}" placeholder="搜索名称或拼音首字母" confirm-type="search" bindinput="inputQuery"/></view>
  <view class="segments"><view class="segment {{tab==='favorite'?'active':''}}" data-tab="favorite" bindtap="switchTab">常用</view><view class="segment {{tab==='local'?'active':''}}" data-tab="local" bindtap="switchTab">食物库</view><view class="segment {{tab==='custom'?'active':''}}" data-tab="custom" bindtap="switchTab">我的食物</view><view class="segment {{tab==='template'?'active':''}}" data-tab="template" bindtap="switchTab">我的套餐</view></view>
  <block wx:if="{{tab!=='template'}}">
    <scroll-view class="filter-scroll" scroll-x><view class="filter-chip {{category===item.key?'active':''}}" wx:for="{{categories}}" wx:key="key" data-category="{{item.key}}" bindtap="setCategory">{{item.label}}</view></scroll-view>
    <button class="btn btn-secondary new-custom" bindtap="newCustom">＋ 创建新食物</button>
    <view class="empty" wx:if="{{!results.length}}">{{tab==='favorite'?'还没有常用食物，点星标收藏':'没有匹配的食物'}}</view>
    <view class="card results" wx:else>
      <view class="list-row" wx:for="{{results}}" wx:key="id" data-index="{{index}}" bindtap="selectFood">
        <view class="grow"><view class="title-line"><view class="strong">{{item.name}}</view><text class="badge">{{item.categoryLabel}}</text></view><view class="small muted">每100g · {{item.caloriesPer100g}}kcal · 蛋{{item.proteinPer100g}} 脂{{item.fatPer100g}} 碳{{item.carbsPer100g}}</view></view>
        <button class="favorite {{item.favorite?'active':''}}" data-id="{{item.id}}" catchtap="toggleFavorite">{{item.favorite?'★':'☆'}}</button>
      </view>
    </view>
  </block>
  <block wx:else>
    <button class="btn btn-secondary new-custom" bindtap="newTemplate">＋ 创建套餐</button>
    <view class="empty" wx:if="{{!mealTemplates.length}}">还没有套餐</view>
    <view class="card results" wx:else><view class="list-row" wx:for="{{mealTemplates}}" wx:key="id"><view class="grow"><view class="strong">{{item.name}}</view><view class="small muted">{{item.components.length}} 种 · {{item.totals.grams}}g · {{item.totals.calories}}kcal</view></view><button class="btn-small btn-primary" data-id="{{item.id}}" bindtap="recordTemplate">记录</button></view></view>
  </block>
</view>
