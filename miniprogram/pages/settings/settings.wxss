.preset-row{display:flex;align-items:center;gap:14rpx}.profile-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12rpx}.body-card{padding-bottom:18rpx}.sex-options{margin-bottom:0}.bmr-result{display:flex;align-items:flex-end;justify-content:space-between;padding-top:18rpx;border-top:1rpx solid var(--separator)}.bmr-number{font-size:52rpx;font-weight:800;color:var(--accent)}.bmr-empty{padding:24rpx 0 6rpx}.body-note{display:block;margin-top:12rpx;line-height:1.5}.theme-options{margin-bottom:12rpx}.save{margin-bottom:32rpx}.backup .btn{margin-top:16rpx}
