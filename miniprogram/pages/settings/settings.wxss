.preset-row{display:grid;grid-template-columns:1fr 1fr;gap:12rpx}.preset-button{min-height:96rpx;display:flex;flex-direction:column;align-items:flex-start;justify-content:center;padding:14rpx 18rpx;background:var(--bg-secondary);color:var(--text-primary);border:1rpx solid var(--separator);text-align:left}.preset-button.active{background:var(--accent-soft);color:var(--accent);border-color:var(--accent)}.preset-ratio{margin-top:5rpx;color:var(--text-secondary);font-size:21rpx;white-space:nowrap}.preset-button.active .preset-ratio{color:var(--accent)}.profile-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12rpx}.body-card{padding-bottom:18rpx}.sex-options{margin-bottom:0}.bmr-result{display:flex;align-items:flex-end;justify-content:space-between;padding-top:18rpx;border-top:1rpx solid var(--separator)}.bmr-number{font-size:52rpx;font-weight:800;color:var(--accent)}.bmr-empty{padding:24rpx 0 6rpx}.body-note{display:block;margin-top:12rpx;line-height:1.5}.theme-options{margin-bottom:12rpx}.save{margin-bottom:32rpx}.backup .btn{margin-top:16rpx}
