.top-actions,.date-nav,.meal-head{display:flex;align-items:center;gap:14rpx}.top-actions{justify-content:space-between;margin-bottom:20rpx}.eyebrow{font-size:22rpx;color:var(--green)}.page-heading{font-size:42rpx;font-weight:800}.settings{width:92rpx;font-size:22rpx}.date-nav{margin-bottom:22rpx}.date-nav picker{flex:1}.date-picker{text-align:center;display:flex;flex-direction:column}.summary-grid{display:grid;grid-template-columns:1fr 1fr;gap:14rpx;margin-bottom:20rpx}.summary-tile{min-height:150rpx;background:var(--surface);border:1rpx solid var(--line);border-radius:12rpx;padding:22rpx;box-sizing:border-box}.tile-label,.tile-sub{display:block;color:var(--muted);font-size:22rpx}.tile-value{font-size:42rpx;font-weight:800}.tile-unit{font-size:22rpx;color:var(--muted)}.progress{height:7rpx;background:var(--line);margin-top:14rpx}.progress-fill{height:100%;background:var(--green)}.workout-card{margin-bottom:28rpx}.workout-mark,.meal-icon{width:62rpx;height:62rpx;border-radius:8rpx;background:#eaf4ee;color:var(--green-dark);font-weight:800;display:flex;align-items:center;justify-content:center}.workout-go{color:var(--green);font-weight:700}.macro-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:12rpx}.macro-item{padding:20rpx;border-radius:10rpx;color:#fff;display:flex;flex-direction:column;gap:6rpx}.macro-item.carbs{background:#2f855a}.macro-item.protein{background:#2563a8}.macro-item.fat{background:#d97706}.macro-value{font-size:34rpx;font-weight:800}.remaining-grid{display:grid;grid-template-columns:repeat(3,1fr);background:var(--surface);border:1rpx solid var(--line);border-radius:12rpx}.remaining-grid>view{padding:20rpx;text-align:center}.remaining-value{display:block;font-size:32rpx;font-weight:800}.recommendation-list{padding-top:0;padding-bottom:0}.meal-head{margin-bottom:10rpx}.meal-head .meal-icon{width:52rpx;height:52rpx}.copy{width:64rpx;height:58rpx;min-height:58rpx;font-size:20rpx;color:var(--muted)}.meal-card{padding-top:0}.food-photo{width:72rpx;height:72rpx;border-radius:8rpx}.food-cal{display:flex;flex-direction:column;text-align:right}.delete{width:56rpx;height:56rpx;min-height:56rpx;padding:0;background:transparent;color:#aab0ac;font-size:38rpx}.add-meal{margin-top:18rpx;min-height:70rpx;background:transparent;color:var(--green);border:2rpx dashed var(--line)}
