<view class="page {{themeClass}}">
  <view class="workout-head"><view><view class="page-heading">训练记录</view><view class="small muted">动作、训练与恢复</view></view><button class="btn btn-primary" bindtap="start">{{active?'继续训练':'开始训练'}}</button></view>
  <view class="segments"><view class="segment {{tab==='current'?'active':''}}" data-tab="current" bindtap="switchTab">训练</view><view class="segment {{tab==='library'?'active':''}}" data-tab="library" bindtap="switchTab">动作库</view><view class="segment {{tab==='history'?'active':''}}" data-tab="history" bindtap="switchTab">历史</view></view>
  <block wx:if="{{tab==='current'}}"><view class="card current-card" wx:if="{{active}}"><view class="badge">进行中</view><view class="current-title">{{active.parts}}</view><view class="muted">{{active.sets}} 组已完成 · {{active.duration}}</view><button class="btn btn-primary" bindtap="start">返回训练</button></view><view class="card current-card" wx:elif="{{latest}}"><view class="small muted">最近一次 · {{latest.date}}</view><view class="current-title">{{latest.parts}}</view><view class="muted">{{latest.durationLabel}} · 约 {{latest.estimatedCalories}} kcal</view><button class="btn btn-primary" bindtap="start">开始新的训练</button></view><view class="empty" wx:else><view class="current-title">开始第一次训练</view><button class="btn btn-primary" bindtap="start">开始训练</button></view></block>
  <block wx:elif="{{tab==='library'}}"><view class="toolbar"><input class="input grow" value="{{query}}" placeholder="搜索动作或肌群" bindinput="inputQuery"/><button class="btn-icon btn-primary" bindtap="newExercise">＋</button></view><scroll-view class="filter-scroll" scroll-x><view class="filter-chip {{filter===item?'active':''}}" wx:for="{{bodyParts}}" wx:key="*this" data-part="{{item}}" bindtap="setFilter">{{item}}</view></scroll-view><view class="card exercise-list"><view class="list-row" wx:for="{{exercises}}" wx:key="id"><view class="swatch">{{item.short}}</view><view class="grow"><view class="strong">{{item.name}}</view><view class="small muted">{{item.bodyPart}}{{item.note?' · '+item.note:''}}{{item.isCustom?' · 自定义':''}}</view></view><button wx:if="{{item.isCustom}}" class="btn-icon btn-small btn-secondary" data-id="{{item.id}}" bindtap="editExercise">改</button><button wx:if="{{item.isCustom}}" class="btn-icon btn-small btn-danger" data-id="{{item.id}}" bindtap="deleteExercise">删</button><button class="btn-icon btn-small btn-secondary" data-id="{{item.id}}" bindtap="addDirect">＋</button></view></view></block>
  <block wx:else><view class="calendar card"><view class="calendar-head"><button class="btn-icon btn-small btn-secondary" data-delta="-1" bindtap="changeMonth">‹</button><text class="strong">{{month}}</text><button class="btn-icon btn-small btn-secondary" data-delta="1" bindtap="changeMonth">›</button></view><view class="week"><text>日</text><text>一</text><text>二</text><text>三</text><text>四</text><text>五</text><text>六</text></view><view class="days"><view wx:for="{{calendar}}" wx:key="key" class="day {{item.blank?'blank':''}} {{item.has?'has':''}} {{item.active?'active':''}}" data-date="{{item.key}}" bindtap="chooseDay">{{item.blank?'':item.day}}</view></view></view><view class="empty" wx:if="{{!dayWorkouts.length}}">{{selectedDate}} 没有训练</view><view class="card history-card" wx:for="{{dayWorkouts}}" wx:key="id"><view class="history-head"><view><view class="strong">{{item.parts}}</view><view class="small muted">{{item.durationLabel}} · 约 {{item.estimatedCalories}} kcal</view></view></view><view class="history-exercise" wx:for="{{item.exerciseRows}}" wx:key="id" wx:for-item="exercise"><view class="row"><view class="grow strong">{{exercise.exerciseName}}</view><button class="btn btn-small btn-secondary" data-id="{{exercise.exerciseId}}" data-name="{{exercise.exerciseName}}" bindtap="showTrend">趋势</button></view><view class="small muted">{{exercise.setsLabel || '无完成组'}}</view></view></view></block>
  <view class="modal-mask" wx:if="{{trend}}" bindtap="closeTrend"><view class="modal-sheet" catchtap="noop"><view class="modal-head"><view class="modal-title">{{trend.name}}趋势</view><button class="btn-icon btn-secondary" bindtap="closeTrend">×</button></view><view class="empty" wx:if="{{!trend.items.length}}">暂无趋势数据</view><block wx:else><canvas type="2d" id="trendCanvas" class="trend-canvas"></canvas><view class="trend-values"><view class="trend-value" wx:for="{{trend.items}}" wx:key="date"><text class="muted">{{item.date}}</text><text>{{item.weight}}kg × {{item.reps}}</text></view></view></block></view></view>
</view>
