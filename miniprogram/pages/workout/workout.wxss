.workout-head,.calendar-head,.history-head,.toolbar{display:flex;align-items:center;justify-content:space-between;gap:14rpx}.workout-head{margin-bottom:22rpx}.page-heading{font-size:40rpx;font-weight:800}.current-card{text-align:center}.current-card .btn{margin-top:24rpx}.current-title{font-size:38rpx;font-weight:800;margin:18rpx 0 8rpx}.toolbar{margin-bottom:18rpx}.exercise-list{padding-top:0;padding-bottom:0}.calendar{margin-bottom:22rpx}.week,.days{display:grid;grid-template-columns:repeat(7,1fr);text-align:center}.week{color:var(--muted);font-size:22rpx;margin:18rpx 0}.day{height:68rpx;display:flex;align-items:center;justify-content:center;border-radius:50%;position:relative}.day.has::after{content:'';position:absolute;bottom:5rpx;width:8rpx;height:8rpx;background:var(--green);border-radius:50%}.day.active{background:var(--green);color:#fff}.day.active::after{background:#fff}.history-card{margin-bottom:16rpx}.history-exercise{padding:20rpx 0;border-top:1rpx solid var(--line)}.trend-row{display:grid;grid-template-columns:150rpx 1fr 180rpx;gap:12rpx;align-items:center;padding:16rpx 0}.trend-line{height:12rpx;background:var(--line)}.trend-line>view{height:100%;background:var(--green)}
