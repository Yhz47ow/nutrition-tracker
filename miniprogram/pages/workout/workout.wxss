.workout-head,.calendar-head,.history-head,.toolbar{display:flex;align-items:center;justify-content:space-between;gap:14rpx}.workout-head{margin-bottom:22rpx}.page-heading{font-size:40rpx;font-weight:800}.current-card{text-align:center}.current-card .btn{margin-top:24rpx}.current-title{font-size:38rpx;font-weight:800;margin:18rpx 0 8rpx}.toolbar{margin-bottom:18rpx}.exercise-list{padding-top:0;padding-bottom:0}.calendar{margin-bottom:22rpx}.week,.days{display:grid;grid-template-columns:repeat(7,1fr);text-align:center}.week{color:var(--text-secondary);font-size:22rpx;margin:18rpx 0}.day{height:68rpx;display:flex;align-items:center;justify-content:center;border-radius:50%;position:relative;color:var(--text-primary)}.day.blank{color:var(--text-tertiary)}.day.has::after{content:'';position:absolute;bottom:5rpx;width:8rpx;height:8rpx;background:var(--accent);border-radius:50%}.day.active{background:var(--accent);color:var(--text-on-accent)}.day.active::after{background:var(--text-on-accent)}.history-card{margin-bottom:16rpx}.history-exercise{padding:20rpx 0;border-top:1rpx solid var(--separator)}.trend-canvas{width:100%;height:360rpx;background:var(--bg-secondary);border:1rpx solid var(--separator);border-radius:8rpx}.trend-values{margin-top:18rpx}.trend-value{display:grid;grid-template-columns:1fr auto;gap:12rpx;padding:14rpx 0;border-bottom:1rpx solid var(--separator)}.trend-value:last-child{border-bottom:0}
