.workout-head,.calendar-head,.history-head,.toolbar,.plan-editor-head{display:flex;align-items:center;justify-content:space-between;gap:14rpx}.workout-head{margin-bottom:22rpx}.page-heading{font-size:40rpx;font-weight:800}.workout-tabs{font-size:24rpx}.current-card{text-align:center}.current-card .btn{margin-top:24rpx}.current-title{font-size:38rpx;font-weight:800;margin:18rpx 0 8rpx}.toolbar{margin-bottom:18rpx}.exercise-list{padding-top:0;padding-bottom:0}.calendar{margin-bottom:22rpx}.calendar-actions{display:flex;align-items:center;gap:10rpx}.week,.days{display:grid;grid-template-columns:repeat(7,1fr);text-align:center}.week{color:var(--text-secondary);font-size:22rpx;margin:18rpx 0}.day{height:68rpx;display:flex;align-items:center;justify-content:center;border-radius:50%;position:relative;color:var(--text-primary)}.day.blank{color:var(--text-tertiary)}.day.has::after{content:'';position:absolute;bottom:5rpx;width:8rpx;height:8rpx;background:var(--accent);border-radius:50%}.day.active{background:var(--accent);color:var(--text-on-accent)}.day.active::after{background:var(--text-on-accent)}.plan-day{height:78rpx;border-radius:10rpx}.plan-day.training{background:var(--accent-soft)}.plan-day.rest{background:var(--bg-tertiary);color:var(--text-secondary)}.plan-day.active{outline:2rpx solid var(--accent);color:var(--text-primary)}.plan-day.active.training{background:var(--accent-soft)}.plan-day.active.rest{background:var(--bg-tertiary)}.plan-mark{position:absolute;bottom:3rpx;font-size:18rpx;line-height:20rpx;color:var(--accent)}.plan-day.rest .plan-mark{color:var(--text-secondary)}.complete-mark{position:absolute;top:2rpx;right:5rpx;color:var(--success);font-size:18rpx;font-weight:800}.calendar-legend{display:flex;align-items:center;justify-content:center;gap:22rpx;margin-top:18rpx;padding-top:16rpx;border-top:1rpx solid var(--separator);color:var(--text-secondary);font-size:22rpx}.calendar-legend>view{display:flex;align-items:center;gap:6rpx}.legend-dot{width:12rpx;height:12rpx;border-radius:50%}.training-dot{background:var(--accent)}.rest-dot{background:var(--text-secondary)}.legend-check{color:var(--success);font-weight:800}.plan-editor{padding:4rpx 2rpx 24rpx}.plan-editor-head{margin-bottom:20rpx}.plan-editor-head .section-title{margin-bottom:2rpx}.day-type-options{margin-bottom:22rpx}.plan-details{min-height:220rpx}.plan-note{min-height:120rpx}.plan-save{margin-top:8rpx}.history-card{margin-bottom:16rpx}.history-exercise{padding:20rpx 0;border-top:1rpx solid var(--separator)}.trend-canvas{width:100%;height:360rpx;background:var(--bg-secondary);border:1rpx solid var(--separator);border-radius:8rpx}.trend-values{margin-top:18rpx}.trend-value{display:grid;grid-template-columns:1fr auto;gap:12rpx;padding:14rpx 0;border-bottom:1rpx solid var(--separator)}.trend-value:last-child{border-bottom:0}
